# Supabase — public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — SERVER ONLY (never expose with NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email) — SERVER ONLY
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Country code API (public — safe to expose)
NEXT_PUBLIC_COUNTRY_API_URL=https://restcountries.com/v3.1/all?fields=name,idd,cca2
